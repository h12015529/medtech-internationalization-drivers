@article{barneyFirmResourcesSustained1991,
  title = {Firm {{Resources}} and {{Sustained Competitive Advantage}}},
  author = {Barney, Jay},
  year = 1991,
  month = mar,
  journal = {Journal of Management},
  volume = {17},
  number = {1},
  pages = {99--120},
  issn = {0149-2063, 1557-1211},
  doi = {10.1177/014920639101700108},
  urldate = {2026-04-23},
  abstract = {Understanding sources of sustained competitive advantage has become a major area of research in strategic management. Building on the assumptions that strategic resources are heterogeneously distributed acrossfirms and that these differences are stable over time, this article examines the link betweenfirm resources and sustained competitive advantage. Four empirical indicators of the potential of firm resources to generate sustained competitive advantage-value, rareness, imitability, and substitutability-are discussed. The model is applied by analyzing the potential of severalfirm resourcesfor generating sustained competitive advantages. The article concludes by examining implications of this firm resource model of sustained competitive advantage for other business disciplines.},
  copyright = {https://journals.sagepub.com/page/policies/text-and-data-mining-license},
  langid = {english}
}

